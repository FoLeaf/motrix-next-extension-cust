{
  "name": "motrix-next-extension",
  "description": "Motrix Next Browser Extension — Send downloads to Motrix Next",
  "private": true,
  "version": "1.2.3",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build -b chromium",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip": "wxt zip -b chromium",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "zip:all": "wxt zip -b chromium && wxt zip -b firefox --mv3",
    "compile": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:i18n": "npx tsx scripts/lint-i18n.ts",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.4.0",
    "@vicons/ionicons5": "^0.13.0",
    "content-disposition": "^1.1.0",
    "fast-deep-equal": "^3.1.3",
    "klona": "^2.0.6",
    "ky": "^2.0.2",
    "lettercoder": "^0.1.1",
    "naive-ui": "^2.44.1",
    "picomatch": "^4.0.4",
    "sanitize-filename": "^1.6.4",
    "vue": "^3.5.29",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/chrome": "^0.1.38",
    "@types/content-disposition": "^0.5.9",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "4.1.2",
    "@vue/test-utils": "^2.4.6",
    "@wxt-dev/module-vue": "^1.0.3",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "unplugin-vue-components": "^32.0.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.5",
    "wxt": "^0.20.20"
  }
}
